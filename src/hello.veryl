module Hello (
    A: input logic,
    B: output logic,
    C: output logic,
) {
    assign B = A;
    assign C = !A;
}

#[test(test_hello)]
module test_hello {
    var a: logic;
    var b: logic;
    var c: logic;

    inst dut: Hello (
        A: a,
        B: b,
        C: c,
    );

    initial {
        a = 1;
        $assert(b == 1 && c == 0);
        a = 0;
        $assert(b == 0 && c == 1);
        $finish();
    }
}
